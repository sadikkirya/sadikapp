rules_versionbases/{database}/documents {
    
    // HELPER FUNCTIONSequest.resource.data.role != 'admin';
 laimin() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role);
 }// VENDORS COLLECTION
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == vendorId && isStatusActive());
    }

    // RIDERS COLLECTION
    match /riders/{riderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == riderId && isStatusActive());
    }

    // ORDERS COLLECTION
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        resource.data.riderId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid
      );
      allow create: if isAuthenticated() && isStatusActive();
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled') ||
        (resource.data.riderId == request.auth.uid) ||
        (resource.data.vendorId == request.auth.uid)
      );
    }

    // PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && getRole() == 'vendor' && request.resource.data.vendorId == request.auth.uid);
    }

    // CHATS SUBCOLLECTION
    match /chats/{chatId}/{document=**} {
      allow read, write: if isAuthenticated() && (
        isAdmin() || 
        exists(/databases/$(database)/documents/orders/$(chatId)) && 
        (
          get(/databases/$(database)/documents/orders/$(chatId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/orders/$(chatId)).data.riderId == request.auth.uid
        )
      );
    }
  }
}